#!/usr/bin/env bash

set -euo pipefail

remote_name="${1:-}"
allow_fucked_branches="$(git config --bool hooks.allowFuckedBranches || echo false)"

while read -r local_ref _ remote_ref _; do
	branch_name=""

	if [[ "$local_ref" == refs/heads/* ]]; then
		branch_name="${local_ref#refs/heads/}"
	elif [[ "$remote_ref" == refs/heads/* ]]; then
		branch_name="${remote_ref#refs/heads/}"
	fi

	if [[ "$remote_name" == "origin" && "$allow_fucked_branches" != "true" ]]; then
		if [[ "$branch_name" == "fucked" || "$branch_name" == fucked/* || "$branch_name" == "mel/fucked" || "$branch_name" == mel/fucked/* ]]; then
			echo "Push blocked: refusing to push branch '$branch_name' to origin for this repo." >&2
			echo "Allow it in this repo with: git config hooks.allowFuckedBranches true" >&2
			exit 1
		fi
	fi
done
